{
  "productName": "Alertes Taches",
  "version": "1.1.19",
  "identifier": "fr.djafar.alertes-taches",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Alertes Taches",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "capabilities": [
        {
          "identifier": "main-window-capability",
          "description": "Allow the main desktop window to use core commands and open native dialogs.",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "dialog:allow-open"
          ]
        },
        {
          "identifier": "sticky-window-capability",
          "description": "Allow sticky note windows to use core window dragging commands.",
          "windows": [
            "sticky-note-*"
          ],
          "permissions": [
            "core:default",
            "core:window:allow-start-dragging"
          ]
        },
        {
          "identifier": "splash-window-capability",
          "description": "Allow the splash window to access the IPC needed for startup rendering.",
          "windows": [
            "splash"
          ],
          "permissions": [
            "core:default"
          ]
        }
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "publisher": "AbouDjafar",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": "fr-FR"
      }
    }
  }
}
